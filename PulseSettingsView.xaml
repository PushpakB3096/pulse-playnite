<UserControl x:Class="Pulse.PulseSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="500" d:DesignWidth="600">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
    </UserControl.Resources>
    <StackPanel Margin="8">
        <CheckBox Content="Automatically sync library changes to PlayLog (playtime, new games, removals)"
                  IsChecked="{Binding Settings.AutoSyncLibrary}"/>
        <TextBlock Margin="0,8,0,0" TextWrapping="Wrap" Foreground="Gray"
                   Text="When enabled, PlayLog syncs after Playnite updates your library. You can still use PlayLog: Sync all games from the main menu."/>

        <TextBlock Margin="0,16,0,0" TextWrapping="Wrap" FontWeight="SemiBold"
                   Text="Achievement source"/>
        <TextBlock Margin="0,4,0,0" TextWrapping="Wrap" Foreground="Gray"
                   Text="Choose which Playnite achievement plugin PlayLog reads from."/>
        <RadioButton Margin="0,8,0,0"
                     Content="PlayniteAchievements"
                     IsChecked="{Binding IsPlayniteAchievementsSelected}"/>
        <RadioButton Margin="0,4,0,0"
                     Content="SuccessStory"
                     IsChecked="{Binding IsSuccessStorySelected}"/>

        <TextBlock Margin="0,6,0,0" TextWrapping="Wrap" Foreground="#CC8800"
                   Visibility="{Binding ShowAchievementSourceChangedWarning, Converter={StaticResource BoolToVisibility}}"
                   Text="Achievement source changed. Run PlayLog: Sync all games from the main menu to update all your games."/>

        <TextBlock Margin="0,16,0,0" TextWrapping="Wrap" FontWeight="SemiBold"
                   Text="PlayLog account"/>

        <StackPanel Visibility="{Binding IsPlayLogLinked, Converter={StaticResource BoolToVisibility}}">
            <TextBlock Margin="0,4,0,0" TextWrapping="Wrap" Foreground="Gray"
                       Text="This PC is linked to your PlayLog account. Library and session sync use the token stored in settings."/>
            <Button Margin="0,8,0,0" Content="Link another device" Click="LinkAccount_Click"/>
        </StackPanel>

        <StackPanel Visibility="{Binding IsPlayLogNotLinked, Converter={StaticResource BoolToVisibility}}">
            <TextBlock Margin="0,4,0,0" TextWrapping="Wrap" Foreground="Gray"
                       Text="Link pairs this PC with your PlayLog account. Enter the short code shown here in the PlayLog app on your phone (signed in)."/>
            <Button Margin="0,8,0,0" Content="Link PlayLog account" Click="LinkAccount_Click"/>
        </StackPanel>

        <StackPanel Margin="0,16,0,0" Visibility="{Binding ShowCoverArtSection, Converter={StaticResource BoolToVisibility}}">
            <TextBlock TextWrapping="Wrap" FontWeight="SemiBold" Text="Cover art"/>
            <TextBlock Margin="0,4,0,0" TextWrapping="Wrap" Foreground="Gray"
                       Text="{Binding CoverUploadStatusText}"/>
        </StackPanel>
    </StackPanel>
</UserControl>
